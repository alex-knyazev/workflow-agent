# Jira
JIRA_BASE_URL=https://your-company.atlassian.net
# Bearer token for Jira API
JIRA_API_TOKEN=your_jira_bearer_token
JIRA_TEAM_PROJECT_KEYS=PAY
JIRA_STACK_FIELD_ID=customfield_12345
JIRA_BUG_ENVIRONMENT_FIELD_ID=customfield_16300
# Sprint custom field used by daily sprint digest rule
JIRA_SPRINT_FIELD_ID=customfield_1005
# Duty backend sprint id included in daily digest
JIRA_DUTY_BACKEND_SPRINT_ID=4007

# Delivery mode: loop | file
NOTIFICATION_MODE=loop
# TEST_MODE=true forces file mode
TEST_MODE=false

# File delivery path when NOTIFICATION_MODE=file or TEST_MODE=true
NOTIFICATION_LOG_PATH=logs/notifications.log

# Loop (Mattermost) incoming webhook
LOOP_WEBHOOK_URL=https://loop.example.com/hooks/your_webhook_id
# Personal DM/channel for rule and fatal error alerts
LOOP_FAILURE_ALERT_CHANNEL=uqcmj4pq7j8zmg5wpou7iaypew
# Destination channel for Kommersant digest notifications
KOMMERSANT_PAYMENTS_NEWS_LOOP_CHANNEL=#team_payments

# Rule management UI / API
RULE_OVERRIDES_PATH=logs/rule-overrides.json
RULE_MANAGEMENT_HOST=127.0.0.1
RULE_MANAGEMENT_PORT=3210
# Work calendar with holidays (Sunday and Saturday are always non-work days)
HOLIDAYS_DATA_PATH=public/data/holidays-2026.json


# Single admin auth for web UI
WEB_ADMIN_LOGIN=your_login
# Generate with: npm run hash:password -- "your-password"
WEB_ADMIN_PASSWORD_HASH=scrypt$base64_salt$base64_hash
WEB_ADMIN_SESSION_TTL_MINUTES=480
