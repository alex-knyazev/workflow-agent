{
  "name": "team-workflow-agent",
  "version": "0.1.0",
  "private": true,
  "description": "DDD-oriented Jira backlog monitor with AI-assisted rule evaluation and Loop notifications",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "hash:password": "tsx scripts/hash-password.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "gray-matter": "^4.0.3",
    "toad-scheduler": "^4.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.1"
  }
}
